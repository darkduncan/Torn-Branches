      #<div class="entry-body">
        #<h2 class="entry-title">Example heading</h2>
        #<div class="entry-text">
          
#<p>text</p>
          #<p>text</p>
        #</div>
      #</div>
    #</article>
         ═══════════════════════════════════════════════════════ -->

    <article>
      <div class="entry-date">14 Jun<br>2026</div>
      <div class="entry-body">
        <h2 class="entry-title">Archive</h2>
        <div class="entry-text">
         <p>Archive</p>
        </div>
      </div>
    </article>

     <article>
      <div class="entry-date">12 Jul 2016<br>2026</div>
      <div class="entry-body">
        <h2 class="entry-title">Archive</h2>
        <div class="entry-text">
          
          <p>Archive</p>
        </div>
      </div>
    </article>
    
    <article>
      <div class="entry-date">3 Jun<br>2026</div>
      <div class="entry-body">
        <h2 class="entry-title">Archive</h2>
        <div class="entry-text">
          <p>Archive</p>
        </div>
      </div>
    </article>

    <article>
      <div class="entry-date">16 May 2016<br>2026</div>
      <div class="entry-body">
        <h2 class="entry-title">Archive</h2>
        <div class="entry-text">
          
<p> Archive</p>
         </div>
      </div>
    </article>
    
    
    <article>
      <div class="entry-date">19 May<br>2026</div>
      <div class="entry-body">
        <h2 class="entry-title">Archive</h2>
        <div class="entry-text">
          <p> Archive</p>
        </div>
      </div>
    </article>

  </main>

  <footer>
    &copy; 2026 Torn Branches
  </footer>

</body>
</html>
