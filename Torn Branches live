<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Torn Branches</title>
  <style>
    /* ── Tokens ─────────────────────────────────────────── */
    :root {
      --bg:        #F7F5F0;
      --ink:       #1A1A18;
      --ink-light: #6B6B65;
      --accent:    #C0533A;
      --rule:      #DDD9D2;
      --col:       1200px;
      --font-body: Georgia, 'Times New Roman', serif;
      --font-ui:   'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    /* ── Reset ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Base ───────────────────────────────────────────── */
    html { background: var(--bg); color: var(--ink); }

    body {
      font-family: var(--font-body);
      font-size: 1.0625rem;
      line-height: 1.75;
      max-width: var(--col);
      margin: 0 auto;
      padding: 0 1.5rem 6rem;
    }

    /* ── Header ─────────────────────────────────────────── */
    header {
      padding: 4rem 0 2.5rem;
      border-bottom: 1px solid var(--ink);
      margin-bottom: 3.5rem;
    }

    /*
      LOGO: Place your PNG file in the same folder as index.html,
      then set the src attribute on the <img class="logo"> tag below.
      The logo displays above the site title at a max width of 80px.
      Remove the entire <img> tag if you don't want a logo.
    */
    .logo {
      display: block;
      max-width: 80px;
      max-height: 80px;
      width: auto;
      height: auto;
      margin-bottom: 1.25rem;
      object-fit: contain;
    }

    header h1 {
      font-family: var(--font-body);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: normal;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }

    header p {
      margin-top: 0.75rem;
      font-family: var(--font-ui);
      font-size: 0.875rem;
      color: var(--ink-light);
      letter-spacing: 0.01em;
    }

    /* ── Entry ──────────────────────────────────────────── */
    /*
      HOW TO ADD A NEW ENTRY:
      Copy the block below (from <article> to </article>)
      and paste it at the TOP of the <main> section.
      Change the date, title, and body text. That's it.
    */
    article {
      display: grid;
      grid-template-columns: 5.5rem 1fr;
      gap: 0 1.75rem;
      padding-bottom: 3rem;
      margin-bottom: 3rem;
      border-bottom: 1px solid var(--rule);
    }

    article:last-child {
      border-bottom: none;
    }

    .entry-date {
      font-family: var(--font-ui);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      padding-top: 0.35rem;
      line-height: 1.4;
    }

    .entry-body {}

    .entry-title {
      font-family: var(--font-body);
      font-size: 1.375rem;
      font-weight: normal;
      line-height: 1.35;
      letter-spacing: -0.01em;
      margin-bottom: 0.9rem;
    }

    .entry-text p {
      margin-bottom: 1em;
      color: #2E2E2A;
    }

    .entry-text p:last-child {
      margin-bottom: 0;
    }

    /* ── Footer ─────────────────────────────────────────── */
    footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--rule);
      font-family: var(--font-ui);
      font-size: 0.8rem;
      color: var(--ink-light);
    }

    /* ── Mobile ─────────────────────────────────────────── */
    @media (max-width: 520px) {
      article {
        grid-template-columns: 1fr;
        gap: 0.4rem 0;
      }
      .entry-date {
        padding-top: 0;
      }
    }
  </style>
</head>
<body>

  <header>
    <!-- LOGO: replace "logo.png" with your filename. Delete this line to remove. -->
    <img class="logo" src="logo.png" alt="Logo" onerror="this.style.display='none'" />
    <h1>Torn Branches</h1>
    <p>I write here. You may read too</p>
  </header>

  <main>

    <!-- ═══════════════════════════════════════════════════════
         ADD NEW ENTRIES HERE — paste a new <article> block
         at the very top, just below this comment.
         
         
         #<article>
